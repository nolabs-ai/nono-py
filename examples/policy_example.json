{
  "meta": {
    "version": 3,
    "schema_version": "3.0"
  },
  "groups": {
    "system_tmp_read": {
      "description": "Allow read-only access to /tmp",
      "allow": {
        "read": [
          "/tmp"
        ]
      }
    },
    "project_rw": {
      "description": "Example project path grant; replace with a real path before using",
      "allow": {
        "readwrite": [
          "/path/to/project"
        ]
      }
    },
    "deny_secrets": {
      "description": "Block common secret directories",
      "deny": {
        "access": [
          "~/.ssh",
          "~/.aws"
        ]
      }
    },
    "offline_mode": {
      "description": "Disable outbound network access",
      "network": {
        "block": true
      }
    },
    "proxy_web_demo": {
      "description": "Allow HTTPS CONNECT only to example.com. Other domains such as evil.com are denied by omission from the allowlist.",
      "network": {
        "allow_proxy": [
          "example.com"
        ],
        "max_connections": 32
      }
    }
  }
}
